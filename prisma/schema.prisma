generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  color     String?
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  tasks     Task[]

  @@index([userId])
}

enum TaskStatus {
  TODO
  DONE
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id           String     @id @default(cuid())
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTaskId String?
  parent       Task?      @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks     Task[]     @relation("TaskSubtasks")
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  priority     Priority   @default(MEDIUM)
  dueDate      DateTime?
  // Fractional-index sort key (see fractional-indexing package) — a plain
  // string so siblings can be reordered/inserted without renumbering rows.
  order        String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([projectId])
  @@index([parentTaskId])
}
